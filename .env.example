# Public (required for auth and API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL (used for canonical URLs, sitemap, Stripe redirects). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://dubaiartradar.com

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-B7PG7MTVGS

# Supabase service role (admin/server-only; optional for public read, required for admin RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_GALLERY_MONTHLY_PRICE_ID=price_...
STRIPE_FEATURE_EVENT_PRICE_ID=price_...
STRIPE_ARTIST_PRO_PRICE_ID=price_...

# OpenRouter (chat + RAG)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
